{
  "name": "slock",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter slock-web dev",
    "server": "bun run --filter slock-web server",
    "build": "tsc -b && bun run --filter slock-web build",
    "start": "bun run --filter slock-web build && bun run --filter slock-web server",
    "preview": "bun run --filter slock-web preview",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "typescript": "~6.0.2"
  }
}
